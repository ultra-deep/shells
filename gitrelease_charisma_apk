isExistApkPathInAzureUrlArray(){
  local environment=$1 # production/staging/develop
  local buildType=$2 # example (one of):  dubeug / release=$1 # production/staging/develop @@@@@@
  for apkUrl in "${apk_azure_urls[@]}"; do # apkUrl = https://azure.charisma.tech/Brokere....
    if($(isExistString $apkUrl $environment) = "true") then
      if($(isExistString $apkUrl $buildType) = "true") then
        echo "true"
        return
      fi
    fi
  done
  echo "false"
}


