move_apk_to_repository() {
  appVersion=$1 #"1.0.29"
  local environment=$2 #"production"
  local buildMode=$3 #"debug"
  local apkFileName="app-$environment-$buildMode.apk"
  local willChangeAPKFileName="trader-$environment-$buildMode-v$appVersion.apk"
  local apkProjectPath="$projectPath/app/$environment/$buildMode/$apkFileName"
  local willChangeAPKPath="$apkRepositoryPath/$environment/$buildMode/$willChangeAPKFileName"

  if [  -f "$willChangeAPKPath" ]; then
    echo -e  "${ORANGE}Already File exits in APK repository : $willChangeAPKPath${NC}"
    apk_azure_urls+=("$(get_azure_url "$environment" "$buildMode" "$willChangeAPKPath")")
    return
  fi


  if [  -f "$apkProjectPath" ]; then
    echo "Renaming apk from  [$apkFileName]  -->  [$willChangeAPKFileName] "
    read -p "Press enter to continue..."
    mv "$apkProjectPath" "$willChangeAPKPath"
    echo -e "${GREEN}Moved apk from:  $apkProjectPath${NC}"
    echo -e "${GREEN}Moved apk to  :  $willChangeAPKPath${NC}"
    apkVersions+=("$environment (v$appVersion)") # production (v1.0.10)
    apk_azure_urls+=("$(get_azure_url "$environment" "$buildMode" "$willChangeAPKFileName")")
  else
    echo -e  "${BRIGHT_BLACK}File not exist! --> $apkProjectPath${NC}"
  fi
}

