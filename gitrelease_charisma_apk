find_position_string () {
  text=$1
  searchKey=$2
  substering_from_searchkey_to_end=${text#*$searchKey}
  echo $(( ${#text} - ${#substering_from_searchkey_to_end} - ${#searchKey} ))
}

sub_string () {
  text=$1
  firstKey=$2
  secondKey=$3
  firstPosition=$(find_position_string "$text" "$firstKey")
